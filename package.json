{
  "name": "krill",
  "version": "0.1.0",
  "description": "Krill design system — a React UI component library",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./dist/esm/index.css": {
      "import": "./dist/esm/index.css",
      "require": "./dist/cjs/index.css"
    }
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "types": "dist/src/index.d.ts",
  "license": "MIT",
  "scripts": {
    "emit-ts": "tsc --build",
    "build": "node build.js",
    "watch": "WATCH=1 npm run build",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "demo": "node demo/serve.js",
    "docs": "node docs/serve.js",
    "llms": "node scripts/generate-llms-txt.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^1.0.1",
    "@floating-ui/react-dom-interactions": "^0.11.0",
    "@mui/material": "^5.10.0",
    "@mui/styles": "^5.9.3",
    "@mui/system": "^5.10.8",
    "@mui/x-date-pickers": "^6.16.2",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@vvo/tzdb": "^6.102.0",
    "date-fns": "^2.30.0",
    "dayjs": "^1.10.7",
    "emotion": "^11.0.0",
    "framer-motion": "^6.3.3",
    "lodash": "^4.17.21",
    "notistack": "^2.0.3",
    "pdfjs-dist": "2.12.313",
    "react-colorful": "^5.6.1",
    "react-device-detect": "^2.2.3",
    "react-dropzone": "^11.4.2",
    "react-pdf": "^5.7.2",
    "react-qrcode-logo": "^2.7.0",
    "react-window": "^1.8.11",
    "styled-components": "^5.3.3"
  },
  "peerDependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.39.4",
    "@types/lodash": "^4",
    "@types/prismjs": "^1.26.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/react-pdf": "^5.0.9",
    "@types/react-window": "^1.8.8",
    "@types/styled-components": "^5.1.24",
    "@types/svgo": "^2",
    "css-loader": "^5.2.6",
    "esbuild": "^0.18.20",
    "esbuild-node-externals": "^1.5.0",
    "esbuild-plugin-svgr": "^1.0.1",
    "esbuild-sass-plugin": "2.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^2.*",
    "prismjs": "^1.29.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "sass": "^1.53.0",
    "svgo": "^2.8.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0"
  }
}
