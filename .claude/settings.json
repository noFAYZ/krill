{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const f=(j.tool_input&&j.tool_input.file_path)||'';if(/\\.tsx?$/.test(f)){const path=require('path');const p=require.resolve('prettier/package.json');require('child_process').execFileSync(process.execPath,[path.join(path.dirname(p),require(p).bin),'--write',f],{stdio:'inherit'});}}catch(e){}});\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
