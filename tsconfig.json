{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["dom", "esnext"],
    "jsx": "react",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationDir": "dist/",
    "outDir": "dist/",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "rootDir": "src"
  },
  "include": ["src", "custom.d.ts"]
}
